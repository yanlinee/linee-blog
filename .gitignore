# ====================
# Hugo 构建输出
# ====================
# 生成的站点文件（部署到 GitHub Pages 时由 CI 生成，不需要提交）
/public/

# Hugo 资源缓存（会自动重新生成）
/resources/_gen/

# Hugo 构建锁文件
.hugo_build.lock

# ====================
# 操作系统文件
# ====================
# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# ====================
# 编辑器/IDE
# ====================
# VS Code
.vscode/
*.code-workspace

# JetBrains
.idea/
*.iml

# Vim
*.swp
*.swo

# Emacs
*~
\#*\#

# ====================
# 日志和临时文件
# ====================
*.log
*.tmp
*.temp

# ====================
# Node.js（如果使用）
# ====================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ====================
# 其他
# ====================
# 本地配置文件（可能包含敏感信息）
.env
.env.local

# 备份文件
*.bak
*.backup

# 大型二进制文件（如果不需要版本控制）
# *.pdf
# *.zip
# *.tar.gz
